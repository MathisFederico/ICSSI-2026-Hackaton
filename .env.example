# copy this file to .env and paste your key in:  cp .env.example .env
# get a key at https://console.anthropic.com/ under settings then api keys
# never commit your real .env or share your key in screenshots or chat
ANTHROPIC_API_KEY=sk-ant-...your-key-here...

# Google BigQuery (Altmetric on GBQ): no env vars needed. Auth is via ADC and
# the active project is read from `gcloud config`. Run once per machine:
#   gcloud auth application-default login
#   gcloud config set project altmetric-endorsements
# (Service-account JSONs don't work here — the Altmetric Analytics Hub
#  subscription applies row-level security to your user identity, not to a SA.)

# Reddit (S7 — for reply traversal in altendor)
# Reddit (only needed if you run altendor's reply traversal on Reddit posts)
# Create a script-type app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USER_AGENT=altendor:icssi-2026 (by /u/your-username)

